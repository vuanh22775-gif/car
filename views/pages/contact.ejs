<div class="min-h-screen bg-gray-50 py-12">
  <div class="container-custom max-w-6xl">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold mb-4">Liên hệ với MOTO</h1>
      <p class="text-gray-600 max-w-2xl mx-auto">Chúng tôi luôn sẵn sàng hỗ trợ bạn 24/7. Hãy liên hệ với chúng tôi qua các kênh dưới đây.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Contact Info -->
      <div class="space-y-6">
        <div class="bg-white rounded-xl shadow-sm p-6">
          <h2 class="text-xl font-semibold mb-6">Thông tin liên hệ</h2>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <i data-lucide="phone" class="text-blue-600 mt-1 w-5 h-5"></i>
              <div><p class="font-medium">Hotline</p><p class="text-gray-600">1900 1234</p><p class="text-sm text-gray-500">8:00 - 22:00 hàng ngày</p></div>
            </div>
            <div class="flex items-start gap-3">
              <i data-lucide="mail" class="text-blue-600 mt-1 w-5 h-5"></i>
              <div><p class="font-medium">Email</p><p class="text-gray-600">support@moto.com</p><p class="text-sm text-gray-500">Phản hồi trong 24h</p></div>
            </div>
            <div class="flex items-start gap-3">
              <i data-lucide="map-pin" class="text-blue-600 mt-1 w-5 h-5"></i>
              <div><p class="font-medium">Địa chỉ</p><p class="text-gray-600">123 Đường ABC, Quận 1, TP.HCM</p></div>
            </div>
            <div class="flex items-start gap-3">
              <i data-lucide="clock" class="text-blue-600 mt-1 w-5 h-5"></i>
              <div><p class="font-medium">Giờ làm việc</p><p class="text-gray-600">Thứ 2 - Thứ 7: 8:00 - 22:00</p><p class="text-gray-600">Chủ nhật: 9:00 - 18:00</p></div>
            </div>
          </div>

          <div class="mt-6 pt-6 border-t">
            <p class="text-sm font-medium text-gray-700 mb-3">Kết nối với chúng tôi</p>
            <div class="flex gap-4">
              <a href="#" class="text-gray-400 hover:text-blue-600 transition"><i data-lucide="facebook" class="w-6 h-6"></i></a>
              <a href="#" class="text-gray-400 hover:text-blue-600 transition"><i data-lucide="instagram" class="w-6 h-6"></i></a>
              <a href="#" class="text-gray-400 hover:text-blue-600 transition"><i data-lucide="youtube" class="w-6 h-6"></i></a>
            </div>
          </div>
        </div>

        <div class="bg-blue-50 rounded-xl p-6 border border-blue-100">
          <h3 class="font-semibold text-blue-900 mb-2">💬 Cần hỗ trợ nhanh?</h3>
          <p class="text-blue-800 text-sm mb-4">Nhấn vào nút bên dưới để trò chuyện với trợ lý ảo Mia của chúng tôi.</p>
          <button id="open-chat-btn" class="flex items-center gap-2 bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition">
            <i data-lucide="message-circle" class="w-5 h-5"></i> Chat với Mia
          </button>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="bg-white rounded-xl shadow-sm p-6">
        <h2 class="text-xl font-semibold mb-6">Gửi tin nhắn</h2>
        <form id="contact-form" class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Họ tên <span class="text-red-500">*</span></label>
            <input type="text" name="name" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Nhập họ tên của bạn" required />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Email <span class="text-red-500">*</span></label>
            <input type="email" name="email" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Nhập email của bạn" required />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Số điện thoại</label>
            <input type="tel" name="phone" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Nhập số điện thoại" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Tiêu đề <span class="text-red-500">*</span></label>
            <input type="text" name="subject" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Nhập tiêu đề" required />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Nội dung <span class="text-red-500">*</span></label>
            <textarea name="message" rows="4" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Nhập nội dung tin nhắn" required></textarea>
          </div>
          <button type="submit" id="contact-submit-btn" class="w-full flex items-center justify-center gap-2 bg-blue-600 text-white py-3 rounded-lg font-medium hover:bg-blue-700 transition disabled:opacity-50">
            <i data-lucide="send" class="w-5 h-5"></i><span id="contact-submit-label">Gửi tin nhắn</span>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script src="/js/contact.js"></script>
