<div class="min-h-screen bg-gray-50 py-8">
  <div class="container mx-auto px-4">
    <!-- Header -->
    <div class="flex flex-wrap justify-between items-center gap-4 mb-6">
      <div>
        <h1 class="text-3xl font-bold">Danh sách xe</h1>
        <p id="vehicles-total-label" class="text-gray-600 mt-1">0 xe đang có sẵn</p>
      </div>
      <div class="flex items-center gap-3">
        <div class="flex bg-white rounded-lg border border-gray-200 p-1">
          <button id="view-grid-btn" class="p-2 rounded bg-blue-100 text-blue-600"><i data-lucide="grid" class="w-[18px] h-[18px]"></i></button>
          <button id="view-list-btn" class="p-2 rounded text-gray-400"><i data-lucide="list" class="w-[18px] h-[18px]"></i></button>
        </div>
        <button id="toggle-filter-btn" class="flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition lg:hidden">
          <i data-lucide="sliders-horizontal" class="w-5 h-5"></i> Bộ lọc
        </button>
      </div>
    </div>

    <div class="flex gap-6">
      <!-- Filter Sidebar -->
      <div id="filter-sidebar" class="hidden lg:block w-full lg:w-72 flex-shrink-0">
        <div id="vehicle-filter-root"></div>
      </div>

      <!-- Vehicle List -->
      <div class="flex-1">
        <div id="vehicles-list-root">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            <% for (let i = 0; i < 6; i++) { %>
              <div class="bg-white rounded-xl overflow-hidden shadow-md animate-pulse">
                <div class="h-48 bg-gray-200"></div>
                <div class="p-4 space-y-3">
                  <div class="h-4 bg-gray-200 rounded w-3/4"></div>
                  <div class="h-4 bg-gray-200 rounded w-1/2"></div>
                  <div class="h-4 bg-gray-200 rounded w-2/3"></div>
                </div>
              </div>
            <% } %>
          </div>
        </div>
        <div id="vehicles-pagination-root" class="flex justify-center gap-2 mt-8"></div>
      </div>
    </div>
  </div>
</div>

<script src="/js/vehicle-card.js"></script>
<script src="/js/vehicle-filter.js"></script>
<script src="/js/vehicles.js"></script>
