<header class="bg-white shadow-md sticky top-0 z-50">
  <div class="container-custom">
    <div class="flex justify-between items-center h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center space-x-2">
        <span class="text-2xl font-bold text-blue-600">MOTO</span>
        <span class="text-sm text-gray-500 hidden sm:inline">Cùng bạn trên mọi hành trình</span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center space-x-6">
        <a href="/" class="text-gray-600 hover:text-blue-600 transition-colors flex items-center space-x-1">
          <i data-lucide="home" class="w-[18px] h-[18px]"></i><span>Trang chủ</span>
        </a>
        <a href="/vehicles" class="text-gray-600 hover:text-blue-600 transition-colors flex items-center space-x-1">
          <i data-lucide="car" class="w-[18px] h-[18px]"></i><span>Xe</span>
        </a>
        <a href="/about" class="text-gray-600 hover:text-blue-600 transition-colors flex items-center space-x-1">
          <i data-lucide="info" class="w-[18px] h-[18px]"></i><span>Giới thiệu</span>
        </a>
        <a href="/contact" class="text-gray-600 hover:text-blue-600 transition-colors flex items-center space-x-1">
          <i data-lucide="phone" class="w-[18px] h-[18px]"></i><span>Liên hệ</span>
        </a>
      </nav>

      <!-- Right side -->
      <div class="flex items-center space-x-2">

        <!-- Đã đăng nhập -->
        <div id="auth-area-loggedin" class="hidden items-center space-x-2">
          <!-- Chuông thông báo -->
          <div id="notification-bell-root"></div>

          <!-- Avatar + Dropdown -->
          <div class="relative">
            <button id="user-menu-btn" class="flex items-center space-x-2 hover:bg-gray-100 p-2 rounded-lg transition">
              <div id="user-avatar-wrap" class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center overflow-hidden">
                <i data-lucide="user" class="w-[18px] h-[18px] text-blue-600"></i>
              </div>
              <span id="user-fullname" class="text-sm font-medium hidden lg:block"></span>
            </button>

            <div id="user-dropdown" class="hidden absolute right-0 mt-2 w-56 bg-white rounded-xl shadow-lg border border-gray-100 py-2 z-50">
              <div class="px-4 py-2 border-b border-gray-100">
                <p id="dropdown-fullname" class="font-medium text-sm"></p>
                <p id="dropdown-email" class="text-xs text-gray-500"></p>
                <span id="dropdown-admin-badge" class="hidden inline-block mt-1 text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded">Admin</span>
              </div>

              <a href="/profile" class="flex items-center space-x-2 px-4 py-2 hover:bg-gray-50 transition">
                <i data-lucide="user-circle" class="w-[18px] h-[18px]"></i><span>Hồ sơ</span>
              </a>
              <a href="/my-vehicles" class="flex items-center space-x-2 px-4 py-2 hover:bg-gray-50 transition">
                <i data-lucide="car" class="w-[18px] h-[18px]"></i><span>Xe của tôi</span>
              </a>
              <a href="/admin" id="dropdown-admin-link" class="hidden flex items-center space-x-2 px-4 py-2 hover:bg-gray-50 transition">
                <i data-lucide="settings" class="w-[18px] h-[18px]"></i><span>Quản trị</span>
              </a>
              <a href="/booking-history" class="flex items-center space-x-2 px-4 py-2 hover:bg-gray-50 transition">
                <i data-lucide="calendar" class="w-[18px] h-[18px]"></i><span>Lịch sử đặt xe</span>
              </a>
              <button id="logout-btn" class="w-full flex items-center space-x-2 px-4 py-2 hover:bg-red-50 text-red-600 transition border-t border-gray-100 mt-1">
                <i data-lucide="log-out" class="w-[18px] h-[18px]"></i><span>Đăng xuất</span>
              </button>
            </div>
          </div>
        </div>

        <!-- Chưa đăng nhập -->
        <div id="auth-area-loggedout" class="hidden md:flex items-center space-x-3">
          <a href="/login" class="px-4 py-2 text-blue-600 border border-blue-600 rounded-lg hover:bg-blue-50 transition">Đăng nhập</a>
          <a href="/register" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">Đăng ký</a>
        </div>

        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden p-2 hover:bg-gray-100 rounded-lg transition">
          <i data-lucide="menu" class="w-6 h-6"></i>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden py-4 border-t border-gray-100">
      <nav class="flex flex-col space-y-3">
        <a href="/" class="flex items-center space-x-2 px-2 py-2 hover:bg-gray-50 rounded-lg transition">
          <i data-lucide="home" class="w-5 h-5"></i><span>Trang chủ</span>
        </a>
        <a href="/vehicles" class="flex items-center space-x-2 px-2 py-2 hover:bg-gray-50 rounded-lg transition">
          <i data-lucide="car" class="w-5 h-5"></i><span>Xe</span>
        </a>
        <a href="/about" class="flex items-center space-x-2 px-2 py-2 hover:bg-gray-50 rounded-lg transition">
          <i data-lucide="info" class="w-5 h-5"></i><span>Giới thiệu</span>
        </a>
        <a href="/contact" class="flex items-center space-x-2 px-2 py-2 hover:bg-gray-50 rounded-lg transition">
          <i data-lucide="phone" class="w-5 h-5"></i><span>Liên hệ</span>
        </a>

        <div id="mobile-auth-loggedout" class="hidden flex-col space-y-2 pt-2 border-t border-gray-100">
          <a href="/login" class="px-4 py-2 text-blue-600 border border-blue-600 rounded-lg text-center hover:bg-blue-50 transition">Đăng nhập</a>
          <a href="/register" class="px-4 py-2 bg-blue-600 text-white rounded-lg text-center hover:bg-blue-700 transition">Đăng ký</a>
        </div>
      </nav>
    </div>
  </div>
</header>
